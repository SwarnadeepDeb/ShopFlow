# Root-level dockerignore (used by docker-compose root context builds)

# Source control
.git
.gitignore

# Secrets
.env
.env.*
*.pem
*.key

# Dependencies
node_modules
**/node_modules

# Build artifacts
**/dist
**/build
**/coverage

# Logs
*.log

# OS / IDE
.DS_Store
Thumbs.db
.vscode
.idea

# Infrastructure / CI — not needed in images
infrastructure/
ansible/
helm/
gitops/
monitoring/
.github/
