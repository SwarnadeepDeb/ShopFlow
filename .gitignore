# ─── Local tooling config ────────────────────────────────────────────────────
.claude/

# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/

# ─── Build outputs ───────────────────────────────────────────────────────────
dist/
build/
coverage/

# ─── Environment / Secrets (NEVER commit real values) ────────────────────────
.env
.env.*
!.env.example

# ─── Terraform ───────────────────────────────────────────────────────────────
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.lock.info
.terraform.lock.hcl
*.tfplan
override.tf
override.tf.json
*_override.tf
*_override.tf.json
*.tfvars
!*.tfvars.example

# ─── Ansible ─────────────────────────────────────────────────────────────────
ansible/group_vars/vault.yml
.vault_pass
*.vault_pass

# ─── SSH keys and certificates ───────────────────────────────────────────────
*.pem
*.key
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.crt
*.cert
*.p12
*.pfx

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
